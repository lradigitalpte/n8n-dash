# Copy to `.env` and fill in deployment URLs from the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.REGION.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.REGION.convex.site

# Auth is configured in code (email/password). Set on the Convex deployment (packages/backend):
#   pnpm exec convex env set BETTER_AUTH_SECRET "<paste 32+ char secret>"
#   pnpm exec convex env set SITE_URL "https://your-app.vercel.app"   # production URL
#   pnpm exec convex env set ADDITIONAL_TRUSTED_ORIGINS "http://localhost:3001"   # optional, for local dev
