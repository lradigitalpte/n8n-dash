# Copy to `.env` and fill in deployment URLs from the Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.REGION.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.REGION.convex.site

# Auth is configured in code (email/password). You must also set these on the
# Convex deployment (not in this file): run from packages/backend
#   pnpm exec convex env set BETTER_AUTH_SECRET "<paste 32+ char secret>"
#   pnpm exec convex env set SITE_URL http://localhost:3001
# SITE_URL must match the URL you use to open the Next app (this repo uses port 3001).
